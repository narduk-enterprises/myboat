{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "myboat-dev",
  "compatibility_date": "2026-03-03",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "myboat-db",
      "database_id": "c56bed08-5796-4f2f-9cc9-9d9b43502f22"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "VESSEL_LIVE_BROKER",
        "class_name": "VesselLiveBroker",
        "script_name": "myboat-vessel-live-broker"
      }
    ]
  },
  "ratelimits": [
    {
      "name": "RL_10",
      "namespace_id": "50110",
      "simple": {
        "limit": 10,
        "period": 60
      }
    },
    {
      "name": "RL_20",
      "namespace_id": "50120",
      "simple": {
        "limit": 20,
        "period": 60
      }
    },
    {
      "name": "RL_30",
      "namespace_id": "50130",
      "simple": {
        "limit": 30,
        "period": 60
      }
    },
    {
      "name": "RL_60",
      "namespace_id": "50160",
      "simple": {
        "limit": 60,
        "period": 60
      }
    },
    {
      "name": "RL_120",
      "namespace_id": "50121",
      "simple": {
        "limit": 120,
        "period": 60
      }
    },
    {
      "name": "RL_240",
      "namespace_id": "50240",
      "simple": {
        "limit": 240,
        "period": 60
      }
    },
    {
      "name": "RL_300",
      "namespace_id": "50300",
      "simple": {
        "limit": 300,
        "period": 60
      }
    }
  ],
  "env": {
    "postgres": {
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": ""
        }
      ]
    }
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "d8dbd41a19e34995bcabe46b8d8dd9c3",
      "preview_id": "cedfd02fe30a45829086c188937059b0"
    }
  ]
}
